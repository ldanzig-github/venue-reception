# Hard-to-guess slug appended to the dashboard URL.
# Generate with: openssl rand -hex 16
VENUE_RECEPTION_PATH_TOKEN=

# HTTP basic auth (user:password).
# Generate password with: openssl rand -hex 24
VENUE_RECEPTION_BASIC_AUTH=

# Where the rendered HTML + scrape JSON are persisted.
# Defaults to ./data relative to the project root.
DATA_DIR=

# Cron-style scrape interval in minutes. Default 30.
SCRAPE_INTERVAL_MINUTES=30

# Port for the Flask/gunicorn server. Default 8090.
PORT=8090
